# Example environment file. Copy to .env and fill in the keys you have.
# Never commit a populated .env — it is gitignored.

# OpenAI (GPT-4o etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=

# Mistral (OpenAI-compatible)
MISTRAL_API_KEY=

# Owner-mode lockdown for public deployments (Cloudflare Tunnel etc.).
# Leave UNSET for personal / local use — all visitors can use the server
# keys above (free for them).
#
# When SET, the server's keys are only usable by requests carrying
#     Authorization: Bearer <HYNI_OWNER_TOKEN>
# in their HTTP headers. Everyone else must enter their OWN API keys in
# the Settings page (BYOK). Use this so you can share hyni.localrun.ai
# with friends without paying their LLM bills.
#
# Recommended: a long random string. Generate with: openssl rand -hex 32
HYNI_OWNER_TOKEN=
